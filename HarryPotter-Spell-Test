import random
import time

spells = {
    "Expelliarmus": "disarms your opponent",
    "Lumos": "creates light",
    "Nox": "extinguishes light",
    "Wingardium Leviosa": "levitates objects",
    "Stupefy": "stuns the target",
    "Accio": "summons an object",
    "Protego": "creates a shield",
    "Alohomora": "unlocks doors",
    "Petrificus Totalus": "freezes the target",
    "Riddikulus": "turns a boggart into something funny",
    "Expecto Patronum": "conjures a Patronus to ward off Dementors",
    "Crucio": "causes unbearable pain",
    "Imperio": "controls the actions of another",
    "Avada Kedavra": "kills opponent(s) instantly"
}

score = 0

print("Welcome to the Harry Potter Spell Guessing Game!")
print("Type your guess for what each spell does.\n")

while True:
    spell = random.choice(list(spells.keys()))
    correct = spells[spell]

    print(f"Spell: {spell}")
    guess = input("What does it do? ").lower().strip()

    if guess in correct.lower():
        print("Correct! ✨")
        score += 1
    else:
        print(f"Not quite! It actually {correct}.")

    again = input("\nPlay again? (y/n): ").lower()
    if again != "y":
        break

print(f"\nFinal score: {score}")
print("Thanks for playing!")

time.sleep(5)
